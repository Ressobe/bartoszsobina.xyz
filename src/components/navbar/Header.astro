---
import HomeLink from './HomeLink.astro';
import AboutLink from './AboutLink.astro'; 
import ProjectsLink from './ProjectsLink.astro';
import BlogLink from './BlogLink.astro';
import GithubLink from './GithubLink.astro';
import ThemeToggle from './ThemeToggle.tsx';
---

<header class="mt-2 md:mt-6 md:px-1">
	<nav class="w-full flex justify-center items-center ">
		<div class="lg:w-3/4 flex flex-col lg:flex-row gap-4 items-center justify-between">

			<div class="flex justify-between ">

				<span class="inline-flex  gap-3 text-content">
          <HomeLink />
          <AboutLink />
          <ProjectsLink />
          <BlogLink />
          <GithubLink />
				</span>

			</div>
      <ThemeToggle client:load />
		</div>
	</nav>
</header>
